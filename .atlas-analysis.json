  "keyFeatures": [
    "Cross-platform C++ audio plugin framework",
    "Support for VST3, AUv2, AUv3, AAX, CLAP, and WAM formats",
    "Multiple graphics backends (NanoVG, Skia)",
    "Rich controls library with 50+ UI widgets",
    "Compile to WebAssembly for browser-based plugins",
    "Alternative UI frameworks (SwiftUI, WebView, Svelte)",
    "MPE-capable polyphonic synthesis support",
    "Built-in DSP utilities and effects",
    "Standalone app and REAPER extension support",
    "iOS, visionOS, and ARM64 platform support"
  ],
  "publicApiSurface": [
    "IPluginBase - Base plugin class with state management",
    "IPlugProcessor - Audio processing base class",
    "IPlug::Parameter - Parameter abstraction",
    "IGraphics - Main graphics context class",
    "IControl - Base UI control class",
    "IVKnobControl - Vector knob control",
    "IVSliderControl - Vector slider control",
    "IVButtonControl - Vector button control",
    "ISender - Audio thread to UI thread data sender",
    "ADSREnvelope - ADSR envelope generator",
    "Oscillator - Multi-waveform oscillator",
    "SVF - State variable filter",
    "Oversampler - Oversampling utility",
    "MidiQueue - MIDI message queue",
    "IMidiMsg - MIDI message structure"
  ]
}
